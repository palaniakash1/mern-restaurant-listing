# For local dev, copy this file to .env.development.local and replace placeholders with real browser keys.
# Vite exposes only variables prefixed with VITE_ to the React app.
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
VITE_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
