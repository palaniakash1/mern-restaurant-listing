{
  "info": {
    "name": "MERN Restaurant - Restaurants API",
    "description": "Restaurant management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000/api"},
    {"key": "adminToken", "value": ""},
    {"key": "superAdminToken", "value": ""},
    {"key": "restaurantId", "value": ""}
  ],
  "item": [
    {
      "name": "Public - Get All Restaurants",
      "request": {
        "method": "GET",
        "url": {"raw": "{{baseUrl}}/restaurants?page=1&limit=10", "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}]}
      }
    },
    {
      "name": "Public - Get Nearby Restaurants",
      "request": {
        "method": "GET",
        "url": {"raw": "{{baseUrl}}/restaurants/nearby?lat=40.7128&lng=-74.0060&radius=10", "query": [{"key": "lat", "value": "40.7128"}, {"key": "lng", "value": "-74.006"}, {"key": "radius", "value": "10"}]}
      }
    },
    {
      "name": "Public - Get Featured Restaurants",
      "request": {"method": "GET", "url": "{{baseUrl}}/restaurants/featured"}
    },
    {
      "name": "Public - Get Trending Restaurants",
      "request": {"method": "GET", "url": "{{baseUrl}}/restaurants/trending"}
    },
    {
      "name": "Public - Get by Slug",
      "request": {"method": "GET", "url": "{{baseUrl}}/restaurants/slug/my-restaurant"}
    },
    {
      "name": "Public - Get Details by Slug",
      "request": {"method": "GET", "url": "{{baseUrl}}/restaurants/slug/my-restaurant/details"}
    },
    {
      "name": "Admin - Create Restaurant",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/restaurants",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"My Restaurant\",\n  \"tagline\": \"Best food in town\",\n  \"description\": \"A great place to eat\",\n  \"address\": {\n    \"addressLine1\": \"123 Main Street\",\n    \"addressLine2\": \"Suite 100\",\n    \"areaLocality\": \"Downtown\",\n    \"city\": \"London\",\n    \"countyRegion\": \"Greater London\",\n    \"postcode\": \"SW1A 1AA\",\n    \"country\": \"United Kingdom\"\n  },\n  \"openingHours\": {\n    \"monday\": {\"open\": \"09:00\", \"close\": \"22:00\", \"isClosed\": false},\n    \"tuesday\": {\"open\": \"09:00\", \"close\": \"22:00\", \"isClosed\": false},\n    \"wednesday\": {\"open\": \"09:00\", \"close\": \"22:00\", \"isClosed\": false},\n    \"thursday\": {\"open\": \"09:00\", \"close\": \"22:00\", \"isClosed\": false},\n    \"friday\": {\"open\": \"09:00\", \"close\": \"23:00\", \"isClosed\": false},\n    \"saturday\": {\"open\": \"10:00\", \"close\": \"23:00\", \"isClosed\": false},\n    \"sunday\": {\"open\": \"10:00\", \"close\": \"21:00\", \"isClosed\": false}\n  },\n  \"contactNumber\": \"+442012345678\",\n  \"email\": \"info@myrestaurant.com\",\n  \"website\": \"https://myrestaurant.com\"\n}"
        }
      }
    },
    {
      "name": "Admin - Get My Restaurant",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/me",
        "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
      }
    },
    {
      "name": "Admin - Get My Restaurant Summary",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/me/summary",
        "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
      }
    },
    {
      "name": "SuperAdmin - Get All Restaurants",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/all",
        "header": [{"key": "Authorization", "value": "Bearer {{superAdminToken}}"}]
      }
    },
    {
      "name": "Owner - Get Restaurant by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/id/:id",
        "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
      }
    },
    {
      "name": "Owner - Update Restaurant",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/restaurants/id/:id",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "body": {"mode": "raw", "raw": "{\n  \"name\": \"Updated Restaurant Name\",\n  \"description\": \"Updated description\"\n}"}
      }
    },
    {
      "name": "Owner - Delete Restaurant",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/restaurants/id/:id",
        "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
      }
    },
    {
      "name": "SuperAdmin - Update Status",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/restaurants/id/:id/status",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{superAdminToken}}"}
        ],
        "body": {"mode": "raw", "raw": "{\n  \"isActive\": true\n}"}
      }
    },
    {
      "name": "SuperAdmin - Restore Restaurant",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/restaurants/id/:id/restore",
        "header": [{"key": "Authorization", "value": "Bearer {{superAdminToken}}"}]
      }
    },
    {
      "name": "SuperAdmin - Change Admin",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/restaurants/id/:id/admin",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{superAdminToken}}"}
        ],
        "body": {"mode": "raw", "raw": "{\n  \"newAdminId\": \"new-admin-user-id\"\n}"}
      }
    }
  ]
}
