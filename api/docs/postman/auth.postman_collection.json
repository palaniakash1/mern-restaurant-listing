{
  "info": {
    "name": "MERN Restaurant - Auth API",
    "description": "Authentication, session lifecycle, and superAdmin auth-governance endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Public - Signup",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/signup",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password1\"\n}"
        }
      }
    },
    {
      "name": "Public - Signin",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/signin",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password1\"\n}"
        }
      }
    },
    {
      "name": "Public - Google OAuth",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/google",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Google User\",\n  \"email\": \"googleuser@example.com\",\n  \"googlePhotoUrl\": \"https://example.com/avatar.jpg\"\n}"
        }
      }
    },
    {
      "name": "Session - Refresh",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/refresh"
      }
    },
    {
      "name": "Auth - Get Session",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/session",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Auth - Change Password",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/change-password",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"Password1\",\n  \"newPassword\": \"Password2\"\n}"
        }
      }
    },
    {
      "name": "Session - List My Sessions",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/sessions",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Session - Revoke My Session",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/auth/sessions/{{sessionId}}",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Session - Signout All Other Sessions",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/signout-all",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Auth - Signout",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/signout",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "SuperAdmin - List User Sessions",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/admin/users/{{userId}}/sessions",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "SuperAdmin - Revoke User Session",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/auth/admin/users/{{userId}}/sessions/{{sessionId}}",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "SuperAdmin - Revoke All User Sessions",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/admin/users/{{userId}}/sessions/revoke-all",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    }
  ]
}
