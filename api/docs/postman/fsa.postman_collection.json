                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Link - Invalid FHRSID (Negative)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/link",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "link"]
            },
            "header": [
              {
                "key": "Content-Type",
