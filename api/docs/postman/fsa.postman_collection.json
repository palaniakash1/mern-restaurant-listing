                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Link - Non-existent FHRSID",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/link",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "link"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fhrsId\": 99999999\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "404 error - FHRSID does not exist in FSA database"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 or 502', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 502]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh - Restaurant Not Linked",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "refresh"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "description": "400 error when trying to refresh a restaurant that is not linked to FSA"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function() {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Status - Restaurant Not Found",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/000000000000000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "000000000000000000000000"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "description": "404 error for non-existent restaurant ID"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404', function() {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "FULL INTEGRATION FLOW",
      "description": "Complete workflow testing the FSA integration",
      "item": [
        {
          "name": "1. Create - Link Restaurant to FHRSID",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/link",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "link"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fhrsId\": {{fhrsId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "2. Verify - Get Restaurant FSA Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "3. Verify - Get Public Rating",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/fsa/rating/{{fhrsId}}",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "rating", "{{fhrsId}}"]
            }
          }
        },
        {
          "name": "4. Refresh - Update Rating",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "refresh"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ]
          }
        },
        {
          "name": "5. Cleanup - Unlink Restaurant",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/fsa/restaurant/{{restaurantId}}/link",
              "host": ["{{baseUrl}}"],
              "path": ["fsa", "restaurant", "{{restaurantId}}", "link"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ]
          }
        }
      ]
    }
  ]
}
