PORT=3000
MONGO="mongodb+srv://username:password@cluster.mongodb.net/database"
JWT_SECRET="your-jwt-secret"
JWT_EXPIRE=1h
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info
OTEL_ENABLED=false
