PORT=3000
NODE_ENV=development

# Prefer DATABASE_URL. MONGO is supported as a legacy fallback.
DATABASE_URL=mongodb://localhost:27017/restaurant
MONGO=

JWT_SECRET=change-me
JWT_EXPIRE=1h

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

REDIS_URL=redis://localhost:6379
CACHE_TTL=300

APP_NAME=mern-restaurant
APP_VERSION=1.0.0

# Protect /api/metrics with this token (x-metrics-token header).
METRICS_TOKEN=

# Required if geocoding from address is used.
GOOGLE_MAPS_API_KEY=
