PORT=3000
MONGO="your-mongodb-uri"
JWT_SECRET="your-secret"
JWT_EXPIRE=1h
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info
OTEL_ENABLED=false
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
REDIS_URL="redis://username:password@host:port"
NODE_ENV="development"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_FOLDER="restaurants"

# ===========================================
# EMAIL CONFIGURATION - OPTIONS FOR LOCALHOST
# ===========================================

# OPTION 1: MAILTRAP (Recommended for Localhost - 100% Free)
# ===========================================
# Sign up: https://mailtrap.io (GitHub login)
# Go to: Email Testing -> Inboxes -> SMTP Settings -> Show Credentials
# Copy username and password from there

EMAIL_PROVIDER=mailtrap
EMAIL_SERVICE_URL=smtps://YOUR_USERNAME:YOUR_PASSWORD@smtp.mailtrap.io:2525
EMAIL_FROM=EatWisely <noreply@eatwisely.com>

# OPTION 2: ETHEREAL EMAIL (Alternative - 100% Free)
# ===========================================
# No signup needed! Auto-generates test account
# Install: npm install nodemailer

# EMAIL_PROVIDER=ethereal
# EMAIL_SERVICE_URL=ethereal
# EMAIL_FROM=EatWisely <noreply@eatwisely.com>

# OPTION 3: RESEND (For Production)
# ===========================================
# Buy a domain, verify DNS, then use:
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_PROVIDER=resend
# EMAIL_FROM=EatWisely <noreply@yourdomain.com>

# Frontend URL (for password reset links)
CLIENT_URL=http://localhost:5173

# ===========================================
# GOOGLE MAPS
# ===========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ===========================================
# PRODUCTION SETTINGS
# ===========================================
# For production, uncomment and configure:
# NODE_ENV=production
# CLIENT_URL=https://yourdomain.com
# EMAIL_FROM=EatWisely <noreply@yourdomain.com>  # Requires verified domain in Resend
